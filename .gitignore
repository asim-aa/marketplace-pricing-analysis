# macOS
.DS_Store

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Test, lint, and coverage caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Environment variables
.env
.env.*
!.env.example

# Raw and generated datasets
data/raw/*
!data/raw/.gitkeep

data/interim/*
!data/interim/.gitkeep

data/processed/*
!data/processed/.gitkeep

data/tableau/*
